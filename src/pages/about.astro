</FullscreenLayout>

<script>
  // 视差滚动效果
  function initParallax() {
    const hero = document.getElementById('hero-section');
    const bgVideo = hero?.querySelector('.hero-bg-video') as HTMLElement | null;
    const heroContent = hero?.querySelector('.hero-content') as HTMLElement | null;
    const scrollHint = document.getElementById('scroll-hint');

    if (!hero || !bgVideo) return;

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const heroHeight = hero.offsetHeight;

      if (scrollY < heroHeight) {
        const ratio = scrollY / heroHeight;
        bgVideo.style.transform = `scale(${1 + ratio * 0.1}) translateY(${scrollY * 0.3}px)`;
        if (heroContent) {
          heroContent.style.opacity = String(1 - ratio * 1.5);
          heroContent.style.transform = `translateY(${scrollY * 0.15}px)`;
        }
        if (scrollHint) {
          scrollHint.style.opacity = String(Math.max(0, 1 - ratio * 3));
        }
      }
    }, { passive: true });

    // 点击滚动到简介
    scrollHint?.addEventListener('click', () => {
      document.getElementById('about-section')?.scrollIntoView({ behavior: 'smooth' });
    });
  }

  // 滚动淡入动画
  function initScrollReveal() {
    const sections = document.querySelectorAll('.skills-section, .site-section, .about-footer');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    sections.forEach(s => observer.observe(s));
  }

  initParallax();
  initScrollReveal();

  // 点击复制邮箱
  const emailBtn = document.getElementById('copy-email');
  emailBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('praxiswalker@gmail.com');
      const span = emailBtn.querySelector('span');
      const orig = span?.textContent;
      if (span) span.textContent = '已复制';
      setTimeout(() => { if (span && orig) span.textContent = orig; }, 1500);
    } catch { /* fallback: silent */ }
  });

  document.addEventListener('astro:page-load', () => {
    initParallax();
    initScrollReveal();
  });
</script>

