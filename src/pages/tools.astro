---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { aiModelNotes, workflowNotes, savingNotes } from '../data/toolkit-notes';

export const prerender = true;

// 1. 读取所有的工具、技能、社群条目
const allDockItems = await getCollection('dockItem', ({ data }) => data.published);

// 提取工具与技能
const tools = allDockItems.filter(item => item.data.category === 'tool');
const skills = allDockItems.filter(item => item.data.category === 'skill');

// 提取社群数据
const communities = allDockItems.filter(item => item.data.category === 'community');
---

<Base 
  title="工具箱 — Walker" 
  description="Walker 正在使用的 AI 工具、工作流和省钱方法。一个对自学者有用的实干装备库。"
>
  <div class="tools-wrapper min-h-screen relative z-10">
    <!-- 💫 空灵流光背景叠层 -->
    <div class="fixed inset-0 -z-30 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="ambient-orb ambient-orb-1 absolute w-[500px] h-[500px] rounded-full blur-[130px] opacity-[0.07] top-[-5%] left-[-5%] animate-subtle-drift-1" style="background-color: var(--orb-color-1, #fee196);"></div>
      <div class="ambient-orb ambient-orb-2 absolute w-[500px] h-[500px] rounded-full blur-[130px] opacity-[0.05] bottom-[-10%] right-[-5%] animate-subtle-drift-2" style="background-color: var(--orb-color-2, #ffafc8);"></div>
    </div>

    <!-- 雾蒙蒙遮罩 -->
    <div class="fixed inset-0 -z-20 pointer-events-none backdrop-blur-[90px] saturate-[120%] bg-transparent" aria-hidden="true"></div>

    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24 relative">
      
      <!-- 头部 -->
      <header class="text-center max-w-2xl mx-auto mb-16 flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand/10 border border-brand/20 shadow-sm mb-6">
          <Icon name="lucide:wrench" width={14} height={14} class="text-brand" />
          <span class="text-[10px] font-mono tracking-[0.25em] uppercase text-brand font-bold">REUSABLE ARSENAL</span>
        </div>

        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-parchment tracking-tight leading-tight mb-4 bg-gradient-to-r from-parchment via-parchment-dim to-brand bg-clip-text text-transparent">
          AI 极客工具箱
        </h1>
        <p class="text-sm sm:text-base text-parchment-dim leading-relaxed">
          这里整理我日常使用的 AI 工具、模型分工和工作流。它不是“越多越好”的收藏夹，而是一个经受过行动验证、极具性价比的实干装备表，帮您在开发和创作中消除信息差，省时省力。
        </p>
      </header>

      <!-- ========================================= -->
      <!-- 1. 社群共创通道 (WeChat & QQ Groups) -->
      <!-- ========================================= -->
      <section class="mb-16">
        <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)] mb-8">
          <Icon name="lucide:users" width={18} height={18} class="text-brand" />
          <h2 class="text-lg font-bold text-parchment flex items-center gap-2">
            社群共创通道 <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Communities</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {communities.map(item => (
            item.data.communities ? (
              /* 多 QQ 群卡片 */
              <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-border)] shadow-sm">
                <div class="flex items-center justify-between border-b border-[var(--color-nav-border)] pb-3 mb-4">
                  <h3 class="text-sm font-bold text-parchment flex items-center gap-2">
                    <Icon name="lucide:users" width={15} height={15} class="text-brand" />
                    {item.data.name}
                  </h3>
                  <span class="text-[10px] font-mono text-parchment-dim opacity-50">QQ GROUPS</span>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {item.data.communities.map(comm => (
                    <div class="p-3.5 rounded-xl border border-[var(--color-nav-border)] bg-parchment/[0.01] hover:border-brand/35 transition-colors">
                      <span class="text-[9px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 py-0.2 rounded">{comm.badge}</span>
                      <h4 class="text-xs font-bold text-parchment mt-2 mb-1">{comm.name}</h4>
                      <p class="text-[10px] text-parchment-dim leading-relaxed">
                        {comm.description}<br/><strong class="text-brand font-mono">{comm.tag}</strong>
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            ) : (
              /* 单旗舰微信群卡片 */
              <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-border)] shadow-sm flex flex-col sm:flex-row items-center gap-5 relative overflow-hidden group/ticket">
                <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-brand/5 blur-2xl group-hover/ticket:bg-brand/10 transition-colors duration-500"></div>
                
                <!-- 二维码 -->
                <div class="w-[100px] h-[100px] bg-white p-2 rounded-xl flex items-center justify-center shrink-0 shadow relative overflow-hidden">
                  <div class="absolute left-0 right-0 top-0 h-[2px] bg-brand animate-[laser-slide_3s_linear_infinite] shadow-[0_0_8px_var(--color-brand)]"></div>
                  <img src={item.data.qrCode || '/images/点子共促.jpg'} alt={`${item.data.name}二维码`} class="w-full h-full object-contain" />
                </div>

                <!-- 文字 -->
                <div class="flex-1 text-center sm:text-left min-w-0">
                  <h3 class="text-sm font-bold text-parchment mb-1.5 flex items-center justify-center sm:justify-start gap-1.5">
                    {item.data.name}
                    <span class="text-[9px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 rounded">微信扫码</span>
                  </h3>
                  <p class="text-[11px] text-parchment-dim leading-relaxed mb-1">
                    {item.data.description}
                  </p>
                  <span class="text-[9.5px] text-brand/90 font-bold">“有点子，先动手，再开口”</span>
                </div>
              </div>
            )
          ))}
        </div>
      </section>

      <!-- ========================================= -->
      <!-- 2. 大模型分工与工作流 (Model Allocations) -->
      <!-- ========================================= -->
      <section class="mb-16 grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- 模型分工 -->
        <div>
          <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)] mb-6">
            <Icon name="lucide:brain" width={16} height={16} class="text-brand" />
            <h2 class="text-md font-bold text-parchment flex items-center gap-2">
              🧠 主力模型分工 <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Models</span>
            </h2>
          </div>
          <div class="flex flex-col gap-4">
            {aiModelNotes.map(([name, desc]) => (
              <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-white/40 shadow-sm flex items-start gap-3">
                <div class="w-5 h-5 rounded bg-brand/15 text-brand flex items-center justify-center text-[10px] shrink-0 font-bold mt-0.5">{name[0]}</div>
                <div>
                  <h3 class="text-xs font-bold text-parchment mb-1">{name}</h3>
                  <p class="text-[11px] text-parchment-dim leading-relaxed">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- 极客工作流 -->
        <div>
          <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)] mb-6">
            <Icon name="lucide:navigation" width={16} height={16} class="text-brand" />
            <h2 class="text-md font-bold text-parchment flex items-center gap-2">
              🧭 极客工作流装备 <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Workflow</span>
            </h2>
          </div>
          <div class="flex flex-col gap-4">
            {workflowNotes.map(([name, desc]) => (
              <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-white/40 shadow-sm flex items-start gap-3">
                <div class="w-5 h-5 rounded bg-amber-500/15 text-amber-500 flex items-center justify-center text-[10px] shrink-0 font-bold mt-0.5">
                  <Icon name="lucide:check" width={10} height={10} />
                </div>
                <div>
                  <h3 class="text-xs font-bold text-parchment mb-1">{name}</h3>
                  <p class="text-[11px] text-parchment-dim leading-relaxed">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ========================================= -->
      <!-- 3. 常用极客开发工具与 Skill -->
      <!-- ========================================= -->
      <section class="mb-16">
        <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)] mb-8">
          <Icon name="lucide:package" width={18} height={18} class="text-brand" />
          <h2 class="text-lg font-bold text-parchment flex items-center gap-2">
            常用开发工具与 Skill <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Arsenal</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {tools.map(item => (
            <div class="panel-glass p-5 rounded-2xl border border-[var(--color-border)] shadow-sm flex flex-col justify-between group">
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[9px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-2 py-0.5 rounded">🛠️ 常用开发工具</span>
                  {item.data.rating && (
                    <span class="text-[10px] text-amber-500 font-bold font-mono">★ {item.data.rating}.0</span>
                  )}
                </div>
                <h3 class="text-sm font-bold text-parchment mb-1.5 group-hover:text-brand transition-colors">{item.data.name}</h3>
                <p class="text-[11px] text-parchment-dim leading-relaxed mb-4">{item.data.description}</p>
              </div>
              {item.data.url && (
                <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="text-xs font-bold text-brand hover:underline flex items-center gap-1 no-underline mt-auto">
                  访问资源网站
                  <Icon name="lucide:external-link" width={11} height={11} />
                </a>
              )}
            </div>
          ))}

          {skills.map(item => (
            <div class="panel-glass p-5 rounded-2xl border border-[var(--color-border)] shadow-sm flex flex-col justify-between group">
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[9px] font-mono text-emerald-500 font-bold bg-emerald-500/5 border border-emerald-500/10 px-2 py-0.5 rounded">✨ 自定义 SKILL</span>
                  {item.data.rating && (
                    <span class="text-[10px] text-amber-500 font-bold font-mono">★ {item.data.rating}.0</span>
                  )}
                </div>
                <h3 class="text-sm font-bold text-parchment mb-1.5 group-hover:text-brand transition-colors">{item.data.name}</h3>
                <p class="text-[11px] text-parchment-dim leading-relaxed mb-4">{item.data.description}</p>
              </div>
              {item.data.url && (
                <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="text-xs font-bold text-brand hover:underline flex items-center gap-1 no-underline mt-auto">
                  查看 Skill 配置
                  <Icon name="lucide:external-link" width={11} height={11} />
                </a>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- ========================================= -->
      <!-- 4. 省钱与降耗建议 (Cost Saving) -->
      <!-- ========================================= -->
      <section class="panel-glass p-6 md:p-8 rounded-[28px] border border-[var(--color-border)] shadow-md">
        <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)] mb-6">
          <Icon name="lucide:piggy-bank" width={16} height={16} class="text-brand" />
          <h2 class="text-md font-bold text-parchment flex items-center gap-2">
            💸 省钱与降耗技巧 <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Cost Saving</span>
          </h2>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {savingNotes.map(([name, desc], idx) => (
            <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-parchment/[0.01] hover:border-brand/20 transition-colors">
              <span class="text-[10px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 py-0.2 rounded">TIPS 0{idx + 1}</span>
              <h3 class="text-xs font-bold text-parchment mt-2 mb-1">{name}</h3>
              <p class="text-[10.5px] text-parchment-dim leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </section>

    </div>
  </div>
</Base>

<style is:global>
  /* 莫兰迪空气感流光漂移关键帧 */
  .animate-subtle-drift-1 {
    animation: subtle-drift-1 22s ease-in-out infinite;
  }
  .animate-subtle-drift-2 {
    animation: subtle-drift-2 26s ease-in-out infinite reverse;
  }

  @keyframes subtle-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
    50% { transform: translate(6%, 5%) scale(1.05) rotate(45deg); }
  }
  @keyframes subtle-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
    50% { transform: translate(-6%, -5%) scale(1.03) rotate(-45deg); }
  }

  /* 扫码卡激光滑块动效 */
  @keyframes laser-slide {
    0%, 100% { top: 0%; opacity: 0; }
    5%, 95% { opacity: 1; }
    50% { top: 100%; }
  }

  /* 面板阴影效果 */
  .panel-glass {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(24px);
    border: 1.5px solid rgba(255, 255, 255, 0.85);
    box-shadow: 
      inset 0 1px 2px rgba(255, 255, 255, 0.6),
      0 4px 18px -4px rgba(26, 35, 37, 0.03),
      0 16px 40px -10px rgba(26, 35, 37, 0.05);
  }
  .panel-glass:hover {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(255, 255, 255, 0.95);
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.7),
      0 8px 24px -6px rgba(26, 35, 37, 0.04),
      0 24px 48px -16px rgba(26, 35, 37, 0.1);
  }
</style>
