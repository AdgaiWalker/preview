---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { POSTS, postSlug, DOCK } from '@/lib/routes';

export const prerender = true;

// 1. 获取所有公开的思考日志 (log)，并按时间排序
const allLogs = (await getCollection('log', ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 仅展示最新的 3 篇，避免过载
const latestThoughts = allLogs.slice(0, 3);

// 2. 为硬核的文章提供大白话“行者导读”
const thoughtGuides: Record<string, string> = {
  'ferry-theory-construction': '💡 大招来了！如果你总是想得多做得少、害怕犯错，请看这个硬核公式。把犯错规范化，它是你唯一的加速器！',
  'dialogue-on-subtraction': '💡 想让 AI 帮你干重活？那你得先学会对自己的脑子做减法。这里有 3 个决策黄金提问。',
  'code-and-philosophy': '💡 写代码犯懒是天性。从哲学视角理解代码抽象，教你如何让 AI 帮你屏蔽掉不必要的冗余细节。',
  'hello-walker': '💡 航海的起点。跟随 Walker 的视角，以纯粹的好奇心与行动开启 AI 时代的探索。',
};
---

<Base title="Walker — 行过万里水路" theme="nature">
  <div class="harbor-wrapper min-h-screen relative z-10">
    
    <!-- ========================================= -->
    <!-- 💫 空灵流光背景叠层 -->
    <!-- ========================================= -->
    <div class="fixed inset-0 -z-30 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="ambient-orb ambient-orb-1 absolute w-[600px] h-[600px] rounded-full blur-[140px] opacity-[0.08] top-[-10%] left-[-10%] animate-subtle-drift-1" style="background-color: var(--orb-color-1, #fee196);"></div>
      <div class="ambient-orb ambient-orb-2 absolute w-[500px] h-[500px] rounded-full blur-[140px] opacity-[0.06] bottom-[-15%] right-[-10%] animate-subtle-drift-2" style="background-color: var(--orb-color-2, #ffafc8);"></div>
      <div class="ambient-orb ambient-orb-3 absolute w-[400px] h-[400px] rounded-full blur-[120px] opacity-[0.06] top-[30%] right-[20%] animate-subtle-drift-3" style="background-color: var(--orb-color-3, #a0f0ff);"></div>
    </div>

    <!-- 雾蒙蒙遮罩 -->
    <div class="fixed inset-0 -z-20 pointer-events-none backdrop-blur-[100px] saturate-[130%] bg-transparent" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 relative">
      
      <!-- ========================================= -->
      <!-- 🌟 第一幕：海港入口（核心初心宣言） -->
      <!-- ========================================= -->
      <header class="text-center max-w-3xl mx-auto mb-16 md:mb-24 flex flex-col items-center">
        <!-- 旗舰徽章 -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand/10 border border-brand/20 shadow-sm mb-6 animate-fade-down">
          <Icon name="lucide:compass" width={14} height={14} class="animate-spin-slow text-brand" />
          <span class="text-[10px] font-mono tracking-[0.25em] uppercase text-brand font-bold">Walker's Harbor</span>
        </div>

        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-extrabold text-parchment tracking-tight leading-tight mb-6 select-none bg-gradient-to-r from-parchment via-parchment-dim to-brand bg-clip-text text-transparent">
          Walker
        </h1>

        <div class="space-y-4 text-parchment/80 text-[14px] sm:text-[15.5px] leading-relaxed tracking-wide text-center">
          <p class="font-bold text-brand">我是秋知 (Walker)，空乘专业在读的 AI 自学者。</p>
          <p>
            做这个博客，在个人层面，是想在有限的现实中给自己一片无限的自由，记录探索环境、行动纠偏的每次思考。
          </p>
          <p>
            同时，我把低成本折腾 AI 提效的心得毫无保留地公开，是为了提供实用的工具与避坑跳板，把更多人从重复劳动中解放出来。
          </p>
          <p class="italic font-serif opacity-90 mt-2 text-brand/90">
            “愿在这个海港里，与志同道合的你相遇，让生活更美好。”
          </p>
        </div>

        <!-- 社交媒体链接胶囊 -->
        <div class="flex flex-wrap justify-center gap-3 mt-8 animate-fade-up">
          <a href="https://github.com/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="social-capsule flex items-center gap-2 px-4.5 py-2 rounded-full border border-[var(--color-nav-border)] bg-white/45 text-sm font-bold hover:bg-black hover:text-white hover:border-black hover:-translate-y-0.5 transition-all duration-300 no-underline shadow-sm">
            <Icon name="lucide:github" width={15} height={15} />
            <span>GitHub</span>
          </a>
          <a href="https://space.bilibili.com/1029612512" target="_blank" rel="noopener noreferrer" class="social-capsule flex items-center gap-2 px-4.5 py-2 rounded-full border border-[var(--color-nav-border)] bg-white/45 text-sm font-bold hover:bg-[#fb7299] hover:text-white hover:border-[#fb7299] hover:-translate-y-0.5 transition-all duration-300 no-underline shadow-sm">
            <Icon name="lucide:circle-play" width={15} height={15} />
            <span>哔哩哔哩</span>
          </a>
          <a href="https://www.xiaohongshu.com/user/profile/689dd905000000001802921e" target="_blank" rel="noopener noreferrer" class="social-capsule flex items-center gap-2 px-4.5 py-2 rounded-full border border-[var(--color-nav-border)] bg-white/45 text-sm font-bold hover:bg-[#ff2442] hover:text-white hover:border-[#ff2442] hover:-translate-y-0.5 transition-all duration-300 no-underline shadow-sm">
            <Icon name="lucide:book-open" width={15} height={15} />
            <span>小红书</span>
          </a>
          <a href="mailto:praxiswalker@gmail.com" class="social-capsule flex items-center gap-2 px-4.5 py-2 rounded-full border border-[var(--color-nav-border)] bg-white/45 text-sm font-bold hover:bg-[var(--color-brand)] hover:text-white hover:border-[var(--color-brand)] hover:-translate-y-0.5 transition-all duration-300 no-underline shadow-sm">
            <Icon name="lucide:mail" width={15} height={15} />
            <span>Email</span>
          </a>
        </div>
      </header>

      <!-- ========================================= -->
      <!-- 🏛️ 第二幕：实干双轨（思考与工具展厅） -->
      <!-- ========================================= -->
      <main class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        
        <!-- ========================================= -->
        <!-- 🧠 左列：思考 (Thoughts - Cos轨 / 决策的脑) -->
        <!-- ========================================= -->
        <section class="flex flex-col gap-6">
          <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)]">
            <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-500">
              <Icon name="lucide:brain" width={16} height={16} />
            </div>
            <div>
              <h2 class="text-xl font-bold text-parchment flex items-center gap-2">
                思考 <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Thoughts</span>
              </h2>
              <p class="text-[11px] text-parchment-dim mt-0.5">理顺思绪，总结行动偏差，Debug 脑子的决策罗盘。</p>
            </div>
          </div>

          <!-- 最新文章日志卡片列表 -->
          <div class="flex flex-col gap-6">
            {latestThoughts.map((log) => (
              <article class="panel-glass p-6 rounded-2xl border border-[var(--color-border)] hover:border-brand/40 hover:-translate-y-1 transition-all duration-300 relative group flex flex-col justify-between shadow-sm">
                <div>
                  <div class="flex items-center justify-between mb-3.5">
                    <span class="text-[10px] font-mono tracking-widest text-brand font-bold bg-brand/5 border border-brand/10 px-2.5 py-0.5 rounded-full uppercase">
                      {log.data.category === 'utopia' ? '🛡️ 行动避难' : log.data.category === 'ai' ? '🦥 极简提效' : '😋 随想灵感'}
                    </span>
                    <time class="text-[11px] font-mono text-parchment-dim opacity-60">
                      {log.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-')}
                    </time>
                  </div>
                  
                  <h3 class="text-[16px] font-bold text-parchment group-hover:text-brand transition-colors mb-3 leading-snug">
                    <a href={postSlug(log.id)} class="no-underline text-current">{log.data.title}</a>
                  </h3>
                  
                  <p class="text-xs text-parchment-dim leading-relaxed mb-4">
                    {log.data.summary || log.data.description || '行过万里水路，记录每一次停靠与思想碰壁。'}
                  </p>
                </div>

                <!-- 大白话新手导读 -->
                {thoughtGuides[log.id] && (
                  <div class="text-[11.5px] italic text-parchment/90 border-l-2 border-brand bg-brand/5 px-3 py-2 rounded-r-lg mb-4.5 font-medium">
                    {thoughtGuides[log.id]}
                  </div>
                )}

                <div class="flex items-center justify-between mt-2 pt-3 border-t border-[var(--color-nav-border)]">
                  <div class="flex gap-1.5">
                    {log.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="text-[9px] font-mono text-parchment-dim bg-parchment/[0.03] px-2 py-0.5 rounded">#{tag}</span>
                    ))}
                  </div>
                  <a href={postSlug(log.id)} class="text-xs font-bold text-brand hover:underline flex items-center gap-1 no-underline">
                    深入阅读
                    <Icon name="lucide:arrow-right" width={12} height={12} />
                  </a>
                </div>
              </article>
            ))}
          </div>

          <!-- 查看全部按钮 -->
          <a href={POSTS} class="w-full py-3.5 rounded-xl border border-[var(--color-nav-border)] hover:border-brand/40 bg-white/40 hover:bg-white/60 text-center font-bold text-xs text-parchment transition-all duration-300 no-underline shadow-sm flex items-center justify-center gap-1.5">
            查看我的全部思考日志
            <Icon name="lucide:chevron-right" width={14} height={14} />
          </a>
        </section>

        <!-- ========================================= -->
        <!-- 🛠️ 右列：工具 (Tools - Sin轨 / 干活的手) -->
        <!-- ========================================= -->
        <section class="flex flex-col gap-6">
          <div class="flex items-center gap-3 pb-3 border-b border-[var(--color-nav-border)]">
            <div class="w-8 h-8 rounded-lg bg-brand/10 flex items-center justify-center text-brand">
              <Icon name="lucide:wrench" width={16} height={16} />
            </div>
            <div>
              <h2 class="text-xl font-bold text-parchment flex items-center gap-2">
                工具 <span class="text-xs font-mono tracking-widest text-parchment-dim uppercase">Tools</span>
              </h2>
              <p class="text-[11px] text-parchment-dim mt-0.5">实体开发武器、极致补给渠道、与“有点子先动手”的共促社区。</p>
            </div>
          </div>

          <div class="flex flex-col gap-6">
            <!-- A. 旗舰单卡：微信点子共促群 (ACCELERATOR PASS) -->
            <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-border)] shadow-md flex flex-col sm:flex-row items-center gap-6 relative overflow-hidden group/ticket">
              <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-brand/5 blur-2xl group-hover/ticket:bg-brand/10 transition-colors duration-500"></div>
              
              <!-- 二维码扫码框 -->
              <div class="w-[120px] h-[120px] bg-white border border-white p-2.5 rounded-2xl flex items-center justify-center shrink-0 shadow-md relative overflow-hidden group-hover/ticket:scale-105 transition-transform duration-300">
                <div class="absolute left-0 right-0 top-0 h-[2px] bg-brand animate-[laser-slide_3s_linear_infinite] shadow-[0_0_8px_var(--color-brand)]"></div>
                <img src="/images/点子共促.jpg" alt="点子共促群二维码" class="w-full h-full object-contain" />
              </div>

              <!-- 卡片信息 -->
              <div class="flex-1 text-center sm:text-left min-w-0">
                <div class="flex items-center justify-center sm:justify-start gap-2 mb-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
                  <span class="text-[9px] font-mono font-bold tracking-widest text-brand uppercase">Flagship Pass</span>
                </div>
                <h3 class="text-[16px] font-bold text-parchment mb-2">🔥 点子共促群 (微信群)</h3>
                <p class="text-xs text-parchment-dim leading-relaxed mb-1">
                  “有点子，先动手，再开口。” 用点子驱动 AI，一起去到一个没有重复劳作的地方。
                </p>
                <span class="text-[10px] text-brand/80 font-bold bg-brand/5 border border-brand/10 px-2 py-0.5 rounded">扫码进群 · 旗舰实干通道</span>
              </div>
            </div>

            <!-- B. 组合卡卡片：常用极客交流群 (QQ群) -->
            <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-border)] shadow-md">
              <div class="flex items-center gap-2 mb-4">
                <Icon name="lucide:users" width={15} height={15} class="text-brand" />
                <h4 class="text-xs font-mono font-bold tracking-widest text-parchment-dim uppercase">极客交流 QQ 群</h4>
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                <!-- QQ群 1 -->
                <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-parchment/[0.02] hover:border-brand/20 transition-colors">
                  <span class="text-[10px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 py-0.2 rounded">插件官方</span>
                  <h5 class="text-xs font-bold text-parchment mt-2 mb-1">Antigravity 官方群</h5>
                  <p class="text-[10.5px] text-parchment-dim leading-relaxed">
                    AI 编程交流、切号插件答疑。<br/><strong class="text-brand font-mono">1025957317</strong>
                  </p>
                </div>
                
                <!-- QQ群 2 -->
                <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-parchment/[0.02] hover:border-brand/20 transition-colors">
                  <span class="text-[10px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 py-0.2 rounded">极客探索</span>
                  <h5 class="text-xs font-bold text-parchment mt-2 mb-1">廉价 AI 探索群</h5>
                  <p class="text-[10.5px] text-parchment-dim leading-relaxed">
                    极致发掘最高性价比开发方案。<br/><strong class="text-brand font-mono">644241363</strong>
                  </p>
                </div>

                <!-- QQ群 3 -->
                <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-parchment/[0.02] hover:border-brand/20 transition-colors">
                  <span class="text-[10px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 py-0.2 rounded">API 中转</span>
                  <h5 class="text-xs font-bold text-parchment mt-2 mb-1">Codex 中转推荐</h5>
                  <p class="text-[10.5px] text-parchment-dim leading-relaxed">
                    秋知自用的稳定 API 中转交流。<br/><strong class="text-brand font-mono">874615899</strong>
                  </p>
                </div>

                <!-- QQ群 4 -->
                <div class="p-4 rounded-xl border border-[var(--color-nav-border)] bg-parchment/[0.02] hover:border-brand/20 transition-colors">
                  <span class="text-[10px] font-mono text-brand font-bold bg-brand/5 border border-brand/10 px-1.5 py-0.2 rounded">账号补给</span>
                  <h5 class="text-xs font-bold text-parchment mt-2 mb-1">廉价 Gemini Pro</h5>
                  <p class="text-[10.5px] text-parchment-dim leading-relaxed">
                    极低门槛 API 售卖交流补给。<br/><strong class="text-brand font-mono">921917596</strong>
                  </p>
                </div>
              </div>
            </div>

            <!-- C. 工具箱总入口卡片 -->
            <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-border)] shadow-md flex flex-col justify-between">
              <div>
                <h3 class="text-[15px] font-bold text-parchment mb-2 flex items-center gap-1.5">
                  <Icon name="lucide:database" width={15} height={15} class="text-brand" />
                  独立实验室探索通道 (Toolkit & Feeds)
                </h3>
                <p class="text-xs text-parchment-dim leading-relaxed mb-4">
                  在这里，我沉淀了独立开发与自学探索期间沉淀的高频 AI 工具箱、技术开发信息源、自研 Claude Skills 等全量数据库，帮您消除信息差。
                </p>
              </div>
              <a href={DOCK} class="py-3 rounded-xl border border-brand/20 hover:border-brand/40 bg-brand/5 hover:bg-brand/10 text-center font-bold text-xs text-brand transition-all duration-300 no-underline shadow-sm flex items-center justify-center gap-1.5">
                进入 AI 极客工具箱大表
                <Icon name="lucide:arrow-up-right" width={14} height={14} />
              </a>
            </div>

          </div>
        </section>

      </main>
      
    </div>
  </div>
</Base>

<style is:global>
  /* 莫兰迪空气感流光漂移关键帧 */
  .animate-subtle-drift-1 {
    animation: subtle-drift-1 22s ease-in-out infinite;
  }
  .animate-subtle-drift-2 {
    animation: subtle-drift-2 26s ease-in-out infinite reverse;
  }
  .animate-subtle-drift-3 {
    animation: subtle-drift-3 24s ease-in-out infinite 1s;
  }

  @keyframes subtle-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
    33% { transform: translate(8%, 6%) scale(1.06) rotate(60deg); }
    66% { transform: translate(-6%, 8%) scale(0.95) rotate(120deg); }
  }
  @keyframes subtle-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
    50% { transform: translate(-8%, -6%) scale(1.04) rotate(-90deg); }
  }
  @keyframes subtle-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(6%, -6%) scale(1.08); }
  }

  /* 扫码卡激光滑块动效 */
  @keyframes laser-slide {
    0%, 100% { top: 0%; opacity: 0; }
    5%, 95% { opacity: 1; }
    50% { top: 100%; }
  }

  /* 面板阴影效果 */
  .panel-glass {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(24px);
    border: 1.5px solid rgba(255, 255, 255, 0.85);
    box-shadow: 
      inset 0 1px 2px rgba(255, 255, 255, 0.6),
      0 4px 18px -4px rgba(26, 35, 37, 0.03),
      0 16px 40px -10px rgba(26, 35, 37, 0.05);
  }
  .panel-glass:hover {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(255, 255, 255, 0.95);
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.7),
      0 8px 24px -6px rgba(26, 35, 37, 0.04),
      0 24px 48px -16px rgba(26, 35, 37, 0.1);
  }
</style>
