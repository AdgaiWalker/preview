    }
    body.theme-aurora #canvas-controls,
    body.theme-sunset #canvas-controls,
    body.theme-mint #canvas-controls {
      background: rgba(18, 14, 38, 0.85);
      border-color: rgba(255, 255, 255, 0.1);
