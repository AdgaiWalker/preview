<script>
  // 视差滚动与浮动导轨高亮逻辑
  function initParallaxAndNav() {
    const hero = document.getElementById('hero-section');
    const bgVideo = hero?.querySelector('.hero-bg-video') as HTMLElement | null;
    const heroContent = hero?.querySelector('.hero-content') as HTMLElement | null;
    const scrollHint = document.getElementById('scroll-hint');
    const floatNav = document.getElementById('about-float-nav');
    const navItems = document.querySelectorAll('.float-nav-item');
    const sections = document.querySelectorAll('.hero-section, .about-section, .cruise-section, .skills-section, .site-section');

    if (!hero) return;

    // 1. 视差滚动事件绑定
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const heroHeight = hero.offsetHeight;

      // 顶部视频视差
      if (scrollY < heroHeight) {
        if (bgVideo) {
          bgVideo.style.transform = `scale(${1 + scrollY / heroHeight * 0.1}) translateY(${scrollY * 0.3}px)`;
        }
        if (heroContent) {
          heroContent.style.opacity = String(1 - scrollY / heroHeight * 1.5);
          heroContent.style.transform = `translateY(${scrollY * 0.15}px)`;
        }
        if (scrollHint) {
          scrollHint.style.opacity = String(Math.max(0, 1 - scrollY / heroHeight * 3));
        }
      }

      // 浮动导轨在离开 Hero 区域后渐显
      if (floatNav) {
        if (scrollY > heroHeight * 0.4) {
          floatNav.classList.add('visible');
        } else {
          floatNav.classList.remove('visible');
        }
      }

      // 滚动监听高亮右侧浮动锚点
      let currentSectionId = 'hero-section';
      sections.forEach(sec => {
        const top = sec.getBoundingClientRect().top;
        if (top <= window.innerHeight * 0.45) {
          currentSectionId = sec.id;
        }
      });

      navItems.forEach(item => {
        const target = item.getAttribute('data-target') || '';
        if (target === currentSectionId) {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });

    }, { passive: true });

    // 2. 点击平滑跳转
    scrollHint?.addEventListener('click', () => {
      document.getElementById('about-section')?.scrollIntoView({ behavior: 'smooth' });
    });

    navItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = item.getAttribute('data-target') || '';
        document.getElementById(targetId)?.scrollIntoView({ behavior: 'smooth' });
      });
    });
  }

  // 3D 物理磁性倾斜与玉石扫光反馈
  function initTiltPostcards() {
    const cards = document.querySelectorAll('.about-pillar-card, .thank-postcard');
    
    cards.forEach((card: any) => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        // 计算旋转倾斜度
        const rotateX = ((y - centerY) / centerY) * -8;
        const rotateY = ((x - centerX) / centerX) * 8;
        
        card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      
      card.addEventListener('mouseleave', () => {
        card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
      });
    });
  }

  // 技能卡片手电筒局部聚光追踪
  function initSpotlightLoadout() {
    const loadoutCards = document.querySelectorAll('.loadout-card');
    
    loadoutCards.forEach((card: any) => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);
      });
    });
  }

  // f(x)=y 文字重力引力波计算
  function initGravityText() {
    const gravityText = document.getElementById('gravity-text');
    const chars = document.querySelectorAll('.gravity-char');
    
    if (!gravityText || chars.length === 0) return;

    window.addEventListener('mousemove', (e) => {
      const mouseX = e.clientX;
      const mouseY = e.clientY;

      chars.forEach((char: any) => {
        const rect = char.getBoundingClientRect();
        const charX = rect.left + rect.width / 2;
        const charY = rect.top + rect.height / 2;

        const distX = mouseX - charX;
        const distY = mouseY - charY;
        const dist = Math.sqrt(distX * distX + distY * distY);

        // 如果鼠标在字符 160px 的辐射引力范围内
        if (dist < 160) {
          const force = (160 - dist) / 160; // 归一化系数 (0~1)
          
          // 微向上浮动，字重变粗，字符微弱放大，改变颜色
          char.style.transform = `translateY(${force * -6}px) scale(${1 + force * 0.16})`;
          char.style.fontWeight = String(Math.floor(400 + force * 400));
          char.style.color = 'var(--color-brand)';
        } else {
          char.style.transform = 'translateY(0) scale(1)';
          char.style.fontWeight = '400';
          char.style.color = 'inherit';
        }
      });
    });

    gravityText.addEventListener('mouseleave', () => {
      chars.forEach((char: any) => {
        char.style.transform = 'translateY(0) scale(1)';
        char.style.fontWeight = '400';
        char.style.color = 'inherit';
      });
    });
  }

  // 站点 LCD 精密运行时间
  function initUptime() {
    const el = document.getElementById('site-uptime');
    if (!el) return;
    
    const launch = new Date('2026-05-02T00:00:00+08:00');
    
    function update() {
      const diff = new Date().getTime() - launch.getTime();
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      
      el.textContent = `SYSTEM ONLINE: ${days}D ${hours}H ${minutes}M ${seconds}S`;
    }
    
    update();
    setInterval(update, 1000);
  }

  // 点击复制邮箱
  function initCopyEmail() {
    const emailBtn = document.getElementById('copy-email');
    emailBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('praxiswalker@gmail.com');
        const span = emailBtn.querySelector('span');
        const orig = span?.textContent;
        if (span) span.textContent = '已复制邮箱';
        setTimeout(() => { if (span && orig) span.textContent = orig; }, 1500);
      } catch { /* fallback */ }
    });
  }

  // 第一次进入时执行
  initParallaxAndNav();
  initTiltPostcards();
  initSpotlightLoadout();
  initGravityText();
  initUptime();
  initCopyEmail();

  // Astro page:load 状态下恢复执行
  document.addEventListener('astro:page-load', () => {
    initParallaxAndNav();
    initTiltPostcards();
    initSpotlightLoadout();
    initGravityText();
    initUptime();
    initCopyEmail();
  });
</script>

