---
/**
 * / — 首页 (即原来的关于页面，合并为整站主入口)
 * 全屏 Hero 视频 + 个人简介 + 技能兴趣 + 项目 + 联系方式
 * 使用 FullscreenLayout
 */
import FullscreenLayout from '../layouts/FullscreenLayout.astro';
import LikeCounter from '../components/LikeCounter.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import avatar from '/public/images/avatar.jpg';

export const prerender = true;
---

<FullscreenLayout
  title="关于 — Walker"
  description="秋知 (Walker) — 航空服务艺术与管理专业，AI 自学者。行过万里水路，记录每一次停靠。"
>
  {/* ===== 全局 Orbs 流光自适应背景 ===== */}
  <div class="fixed inset-0 -z-30 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="ambient-orb ambient-orb-1" style="background-color: var(--orb-color-1, #fee196);"></div>
    <div class="ambient-orb ambient-orb-2" style="background-color: var(--orb-color-2, #ffafc8);"></div>
    <div class="ambient-orb ambient-orb-3" style="background-color: var(--orb-color-3, #a0f0ff);"></div>
    <div class="ambient-orb ambient-orb-4" style="background-color: var(--orb-color-4, #b4f5cd);"></div>
  </div>

  {/* ===== 右侧悬浮极简微导轨导航 (Floating Nav Guide) ===== */}
  <div class="about-floating-nav" id="about-float-nav" aria-label="页面导轨">
    <a href="#hero-section" class="float-nav-item active" data-target="hero-section" title="顶部">
      <Icon name="lucide:arrow-up" width={16} height={16} />
      <span class="float-nav-hint">回到顶部</span>
    </a>
    <a href="#about-section" class="float-nav-item" data-target="about-section" title="简介">
      <Icon name="lucide:user" width={16} height={16} />
      <span class="float-nav-hint">关于秋知</span>
    </a>
    <a href="#cruise-section" class="float-nav-item" data-target="cruise-section" title="日志">
      <Icon name="lucide:ship" width={16} height={16} />
      <span class="float-nav-hint">航海日志</span>
    </a>
    <a href="#skills-section" class="float-nav-item" data-target="skills-section" title="装备">
      <Icon name="lucide:swords" width={16} height={16} />
      <span class="float-nav-hint">硬核装备</span>
    </a>
    <a href="#site-section" class="float-nav-item" data-target="site-section" title="本站">
      <Icon name="lucide:scroll" width={16} height={16} />
      <span class="float-nav-hint">关于本站</span>
    </a>
  </div>

  {/* ===== Hero 区域（视频背景与磨砂噪点蒙版） ===== */}
  <section class="hero-section" id="hero-section">
    <div class="hero-bg">
      <video
        class="hero-bg-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="/video/A-storyboard-2.mp4"
      >
        <source src="/video/A-storyboard-2.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>

    {/* 中心内容 */}
    <div class="hero-content">
      <div class="hero-badge">
        <span class="hero-dot"></span>
        <span>探索中</span>
      </div>
      <h1 class="hero-title">Walker</h1>
      <p class="hero-tagline">行过万里水路，记录每一次停靠</p>
    </div>

    {/* 向下滚动提示 */}
    <div class="hero-scroll-hint" id="scroll-hint">
      <Icon name="lucide:chevron-down" width={24} height={24} />
    </div>
  </section>

  {/* ===== 个人简介区域 (三折页卡片重塑) ===== */}
  <section class="about-section py-20 px-4 sm:px-6 flex justify-center" id="about-section">
    <div class="about-card panel-glass max-w-[620px] w-full p-8 sm:p-10 relative overflow-hidden">
      
      {/* 头像 */}
      <div class="about-avatar-wrapper flex flex-col items-center mb-6">
        <div class="about-avatar border-2 border-[var(--color-brand)] p-0.5 rounded-full overflow-hidden shadow-lg transition-transform duration-500 hover:rotate-6">
          <Image src={avatar} alt="秋知" width={96} height={96} class="rounded-full object-cover" />
        </div>
        <h2 class="about-name text-2xl font-bold mt-4 flex items-center gap-2">
          秋知 <span class="about-name-en text-sm font-mono text-parchment-dim">Walker</span>
        </h2>
      </div>

      {/* 身份微卡 (三折页设计) */}
      <div class="about-labels-grid grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
        <div class="about-pillar-card p-3 rounded-xl border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.03)] flex flex-col items-center text-center transition-all duration-300 hover:border-brand/40 hover:-translate-y-1">
          <Icon name="lucide:graduation-cap" width={18} height={18} class="text-[var(--color-brand)] mb-1" />
          <span class="text-xs font-semibold">空乘专业</span>
          <span class="text-[10px] text-parchment-dim mt-0.5">蓝天下的探索视野</span>
        </div>
        <div class="about-pillar-card p-3 rounded-xl border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.03)] flex flex-col items-center text-center transition-all duration-300 hover:border-brand/40 hover:-translate-y-1">
          <Icon name="lucide:scale" width={18} height={18} class="text-[var(--color-brand)] mb-1" />
          <span class="text-xs font-semibold">马哲方法论</span>
          <span class="text-[10px] text-parchment-dim mt-0.5">行动、验证与纠偏</span>
        </div>
        <div class="about-pillar-card p-3 rounded-xl border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.03)] flex flex-col items-center text-center transition-all duration-300 hover:border-brand/40 hover:-translate-y-1">
          <Icon name="lucide:cpu" width={18} height={18} class="text-[var(--color-brand)] mb-1" />
          <span class="text-xs font-semibold">自学 AI</span>
          <span class="text-[10px] text-parchment-dim mt-0.5">以极小成本撬动大落地</span>
        </div>
      </div>

      {/* 社交链接 */}
      <div class="about-social flex flex-wrap justify-center gap-3 mb-8">
        <a href="https://github.com/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-black hover:text-white hover:border-black transition-all">
          <Icon name="lucide:github" width={16} height={16} />
          <span>GitHub</span>
        </a>
        <a href="https://space.bilibili.com/1029612512" target="_blank" rel="noopener noreferrer" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-[#fb7299] hover:text-white hover:border-[#fb7299] transition-all">
          <Icon name="lucide:circle-play" width={16} height={16} />
          <span>Bilibili</span>
        </a>
        <a href="https://www.xiaohongshu.com/user/profile/689dd905000000001802921e" target="_blank" rel="noopener noreferrer" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-[#ff2442] hover:text-white hover:border-[#ff2442] transition-all">
          <Icon name="lucide:book-open" width={16} height={16} />
          <span>小红书</span>
        </a>
        <button type="button" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-[var(--color-brand)] hover:text-white hover:border-[var(--color-brand)] transition-all cursor-pointer" id="copy-email">
          <Icon name="lucide:mail" width={16} height={16} />
          <span>Email</span>
        </button>
      </div>

      <div class="border-b border-[var(--color-nav-border)] mb-8 opacity-40"></div>

      {/* 介绍文案 */}
      <div class="about-bio text-sm leading-relaxed text-parchment/80 space-y-4">
        <p>
          我是秋知，航空服务艺术与管理专业在读（28 届）。空乘专业给了我时间，马哲给了我方法，AI 给了我路。
        </p>

        {/* 哲理生活观金句卡片 */}
        <div class="bio-quote-callout p-5 rounded-2xl border border-[var(--color-nav-border)] bg-[var(--color-brand-glow)] my-6 relative overflow-hidden">
          <div class="absolute right-4 bottom-1 text-[var(--color-brand)] opacity-[0.06] select-none pointer-events-none" style="font-size: 5rem; font-family: Georgia, serif;">”</div>
          <p class="font-heading text-[14px] font-bold text-parchment leading-relaxed text-center italic m-0">
            “最好的生活状态是，带着自己的目标，准备出发、正在出发、歇会再出发。”
          </p>
        </div>
        <p>
          25 年 8 月底因自创项目需要，全心投入 AI 工程实践。已独立上线 AI 辅助工具站 <a href="https://www.xyzidea.com" target="_blank" rel="noopener noreferrer" class="font-bold underline decoration-brand">xyzidea.com</a>。
        </p>
        
        {/* 40元硬核投入卡片 */}
        <div class="bio-callout p-4 rounded-xl border-l-4 border-brand bg-[var(--color-brand-glow)] my-6">
          <p class="font-medium text-parchment/90">
            学习期间月均生活费不足两千，AI 投入月均 <strong class="text-brand">40 元</strong>。条件虽然有限，但足够在数字世界里扬帆起航。
          </p>
        </div>

        <p>
          一路走来，秋芝引我入门，海哥（海拉鲁编程客）带我成长，刘、于二老在迷茫时点醒方向。感谢虽不理解但给予经济支持的亲人。
        </p>
        <p>
          现正设计独立博客 <a href="https://iwalk.pro" target="_blank" rel="noopener noreferrer" class="font-bold">iwalk.pro</a>，构建 <a href="https://github.com/AdgaiWalker/Ferry" target="_blank" rel="noopener noreferrer" class="font-bold">Ferry</a> 自适应提示词工程框架——让人机协作有据可循，筹备 AI 共创社区 <a href="https://www.xyzidea.cn" target="_blank" rel="noopener noreferrer" class="font-bold">点子</a>（xyzidea.cn）。让 AI 落地，发现真实需求，解决真实问题。做最好的 AI 普及。向具身智能方向前进，为人的解放出一份力。
        </p>
        <p>
          空杯，行动，验证，纠偏。把人从重复劳动中解放出来，去追求真正的幸福。
        </p>

        {/* f(x) = y 物理挤压引力文字区 */}
        <div class="py-6 flex flex-col items-center justify-center">
          <p class="bio-highlight flex items-center justify-center flex-wrap select-none font-bold text-lg cursor-default tracking-wider" id="gravity-text">
            {"世界是一个巨大的 f(x) = y".split('').map((char) => (
              <span class="gravity-char inline-block transition-all duration-300 ease-out">{char === ' ' ? '\u00A0' : char}</span>
            ))}
          </p>
          <span class="text-[10px] text-parchment-dim mt-2 tracking-widest uppercase">物理引力波交互区 · 鼠标划过触控</span>
        </div>
      </div>
    </div>
  </section>

  {/* ===== 纵向 SVG 航海日志时间轴 (Cruise Log) ===== */}
  <section class="cruise-section py-20 px-4 sm:px-6 flex flex-col items-center relative overflow-hidden" id="cruise-section">
    <div class="section-header max-w-[700px] w-full mb-16 flex items-center gap-4">
      <h2 class="section-title text-sm font-bold text-parchment-dim tracking-widest">数字航行停靠日志</h2>
      <div class="section-line flex-1 h-px bg-gradient-to-r from-[var(--color-nav-border)] to-transparent"></div>
    </div>

    <div class="cruise-timeline-container max-w-[620px] w-full relative py-6">
      <!-- 🔭 Voyager Philosophical Manifesto (哲理常驻引力金句) -->
      <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-nav-border)] mb-12 relative overflow-hidden group/philosophy shadow-lg">
        {/* 淡金色与薄荷绿空气感流光背景呼吸发光点 */}
        <div class="absolute -right-20 -top-20 w-44 h-44 rounded-full bg-amber-400/10 blur-3xl group-hover/philosophy:bg-amber-400/18 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-44 h-44 rounded-full bg-[var(--color-brand-glow)] blur-3xl opacity-50"></div>
        
        <div class="relative z-10 flex flex-col gap-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/20 flex items-center justify-center text-brand shrink-0 shadow-sm mt-0.5 group-hover/philosophy:scale-105 transition-transform duration-300">
              <Icon name="lucide:compass" width={18} height={18} class="animate-spin-slow text-brand" />
            </div>
            <div>
              <p class="font-serif text-[15px] sm:text-[16px] text-parchment leading-relaxed tracking-wide font-medium italic">
                “ 最好的生活状态是，带着自己的目标，准备出发、正在出发、歇会再出发。 ”
              </p>
              <p class="text-[9px] font-mono tracking-widest text-parchment-dim opacity-50 uppercase mt-2">
                — VOYAGER'S SPIRITUAL MANIFESTO / 航行者宣言
              </p>
            </div>
          </div>
          
          {/* 三态物理流动指示器 */}
          <div class="flex items-center justify-around bg-[rgba(0,0,0,0.03)] dark:bg-[rgba(255,255,255,0.03)] border border-[var(--color-nav-border)] rounded-2xl p-2.5 mt-1">
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] font-body text-parchment-dim/60 font-semibold cursor-default">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 opacity-60"></span>
              准备出发
            </div>
            <div class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-xl text-[11.5px] font-body text-brand font-black bg-brand/10 border border-brand/20 shadow-sm cursor-default">
              <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
              正在出发
            </div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] font-body text-parchment-dim/60 font-semibold cursor-default">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 opacity-60"></span>
              歇会再出发
            </div>
          </div>
        </div>
      </div>
      
      {/* 纵向发光虚线航道 */}
      <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-0.5 sm:-translate-x-1/2 bg-dashed border-l border-brand/40 -z-10"></div>
      
      {/* 停靠点 1: 航线开启 */}
      <div class="timeline-anchor relative flex flex-col sm:flex-row items-start sm:justify-between gap-8 mb-16 w-full">
        <div class="timeline-marker absolute left-4 sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full flex items-center justify-center bg-[var(--color-bg)] border-2 border-brand z-20 cursor-default">
          <span class="marker-dot w-2.5 h-2.5 rounded-full bg-brand"></span>
          <span class="marker-ripple absolute inset-0 rounded-full border border-brand opacity-0"></span>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0 sm:text-right">
          <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">2025.08</span>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0">
          <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300">
            <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5 sm:justify-start">
              <Icon name="lucide:anchor" width={14} height={14} class="text-brand" />
              全速驶入 AI 数字深海
            </h4>
            <p class="text-xs text-parchment/70 leading-relaxed">
              因为自创项目需要，全身心投入 AI 工程落地实践。从写下第一行 Python 和第一个自适应 Prompt 开始，开启硬核数字航线。
            </p>
          </div>
        </div>
      </div>

      {/* 停靠点 2: 独立上线 */}
      <div class="timeline-anchor relative flex flex-col sm:flex-row items-start sm:justify-between gap-8 mb-16 w-full">
        <div class="timeline-marker absolute left-4 sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full flex items-center justify-center bg-[var(--color-bg)] border-2 border-brand z-20 cursor-default">
          <span class="marker-dot w-2.5 h-2.5 rounded-full bg-brand"></span>
          <span class="marker-ripple absolute inset-0 rounded-full border border-brand opacity-0"></span>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-2 sm:order-1 sm:text-right">
          <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300">
            <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5 justify-start sm:justify-end">
              独立上线 xyzidea.com
              <Icon name="lucide:ship" width={14} height={14} class="text-brand" />
            </h4>
            <p class="text-xs text-parchment/70 leading-relaxed">
              历经三个月的反复验证纠偏，独立开发的 AI 辅助点子工具站成功部署上线，开始服务首批独立创作者同好。
            </p>
          </div>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-1 sm:order-2">
          <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">2025.11</span>
        </div>
      </div>

      {/* 停靠点 3: Ferry 框架与点子社区 */}
      <div class="timeline-anchor relative flex flex-col sm:flex-row items-start sm:justify-between gap-8 mb-16 w-full">
        <div class="timeline-marker absolute left-4 sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full flex items-center justify-center bg-[var(--color-bg)] border-2 border-brand z-20 cursor-default">
          <span class="marker-dot w-2.5 h-2.5 rounded-full bg-brand"></span>
          <span class="marker-ripple absolute inset-0 rounded-full border border-brand opacity-0"></span>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0 sm:text-right">
          <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">2026.05</span>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0">
          <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300">
            <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5">
              <Icon name="lucide:compass" width={14} height={14} class="text-brand" />
              设计 Ferry 框架与点子社区
            </h4>
            <p class="text-xs text-parchment/70 leading-relaxed">
              为让人机协作有章可循，设计了 Ferry 自适应提示词架构，并同步开启 xyzidea.cn 社区的筹备，赋能更多 AI 普及。
            </p>
          </div>
        </div>
      </div>

      {/* 停靠点 4: 感恩致谢 (3D 明信片信封) */}
      <div class="timeline-anchor relative flex flex-col sm:flex-row items-start sm:justify-between gap-8 w-full">
        <div class="timeline-marker absolute left-4 sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full flex items-center justify-center bg-[var(--color-bg)] border-2 border-brand z-20 cursor-default">
          <span class="marker-dot w-2.5 h-2.5 rounded-full bg-brand"></span>
          <span class="marker-ripple absolute inset-0 rounded-full border border-brand opacity-0"></span>
        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-2 sm:order-1 sm:text-right">
          
          {/* 致谢 3D 明信片 */}
          <div class="panel-glass thank-postcard p-6 relative overflow-hidden transition-all duration-500 hover:rotate-1 text-left sm:text-left">
            <div class="thank-postcard-stamp absolute top-4 right-4 border-2 border-dashed border-brand/40 p-1 text-[9px] text-brand select-none opacity-40 font-mono tracking-widest">
              航行信戳
            </div>
            <h4 class="text-sm font-bold mb-3 flex items-center gap-2 text-brand">
              <Icon name="lucide:heart" width={16} height={16} />
              致我的引路人与恩师
            </h4>
            <p class="text-xs leading-relaxed text-parchment/70 italic">
              “一路走来，秋芝引我入门，海哥（海拉鲁编程客）带我成长，刘、于二老在迷茫时点醒方向。感谢虽不理解但给予经济支持的亲人。水路万里，停靠因你们而有据可循。”
            </p>
          </div>

        </div>
        <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-1 sm:order-2">
          <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">NOW</span>
        </div>
      </div>

    </div>
  </section>

  {/* ===== 技能与兴趣：硬核装备库 (Tech Loadout) ===== */}
  <section class="skills-section py-20 px-4 sm:px-6 flex flex-col items-center relative overflow-hidden" id="skills-section">
    <div class="skills-container max-w-[700px] w-full">
      <div class="section-header mb-12 flex items-center gap-4">
        <h2 class="section-title text-sm font-bold text-parchment-dim tracking-widest">秋知的硬核装备库</h2>
        <div class="section-line flex-1 h-px bg-gradient-to-r from-[var(--color-nav-border)] to-transparent"></div>
      </div>

      {/* 装备格 GRID */}
      <div class="skills-grid grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        
        {/* 装备一: 主武器 */}
