---
import Base from '../layouts/Base.astro';
import GreetingCard from '../components/GreetingCard.astro';
import RecentTraces from '../components/RecentTraces.astro';
import BrandCard from '../components/BrandCard.astro';
import DockShowcase from '../components/DockShowcase.astro';


import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

export const prerender = true;

// 动态载入真实的文章集合
const allLogs = await getCollection('log', ({ data }) => data.published);
const aiLogs = allLogs
  .filter(log => log.data.category === 'ai')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Walker — 行过万里水路" theme="nature">

  <!-- ========================================= -->
  <!-- 首页全屏画布容器 (背景画板已固定，不再支持全画布平移，避免失焦) -->
  <!-- ========================================= -->
  <div id="canvas-container" class="fixed inset-0 overflow-hidden select-none pointer-events-auto z-0 flex items-center justify-center">
    
    <!-- 动态流动背景层 (莫兰迪空气感柔和微偏色渐变舞台) -->
    <div id="dynamic-bg-glows" class="absolute inset-0 -z-30 overflow-hidden pointer-events-none transition-all duration-1000">
      <!-- 四个超大、高雅极淡的空气感 Orb (通过 CSS 变量动态绑定颜色) -->
      <div class="glow-orb absolute w-[80vw] h-[80vw] rounded-full blur-[160px] opacity-[0.10] transition-all duration-1000" id="orb-1"></div>
      <div class="glow-orb absolute w-[70vw] h-[70vw] rounded-full blur-[160px] opacity-[0.08] transition-all duration-1000" id="orb-2"></div>
      <div class="glow-orb absolute w-[60vw] h-[60vw] rounded-full blur-[140px] opacity-[0.08] transition-all duration-1000" id="orb-3"></div>
      <div class="glow-orb absolute w-[55vw] h-[55vw] rounded-full blur-[140px] opacity-[0.08] transition-all duration-1000" id="orb-4"></div>
    </div>

    <!-- 雾蒙蒙遮罩层：高强度的模糊与极低对比色相融，形成空灵的透射偏色迷雾 -->
    <div id="mist-overlay" class="absolute inset-0 -z-10 pointer-events-none backdrop-blur-[120px] saturate-[140%] transition-all duration-1000"></div>

    <!-- 桌面网格噪声纹理叠层 (给迷雾带来实体的物气纹理细节) -->
    <div class="absolute inset-0 -z-5 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>

    <!-- 缩放与平移的桌面画布 (高度缩窄至精致的 560px，空出高昂呼吸空间，一屏全包揽) -->
    <div id="desktop-canvas" class="absolute w-[1060px] h-[560px] pointer-events-none transition-transform duration-300 origin-center flex justify-center items-center">
      
      <!-- 三栏 Bento Box 布局 (极其均衡平整的黄金比例，间距收窄至 gap-5.5) -->
      <div class="grid grid-cols-[250px_430px_280px] justify-center gap-5.5 items-start w-full relative pb-4 pointer-events-auto px-4">

        <!-- ========================================= -->
        <!-- 左栏：最近文章 + 搜索 -->
        <!-- ========================================= -->
        <div class="flex flex-col gap-4.5 mt-2">
          <!-- 最近文章 (读取真实的本地文章列表) -->
          <div class="pop-in delay-1 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[32px]">
            <RecentTraces logs={aiLogs} />
          </div>

          <!-- 极简毛玻璃搜索入口 -->
          <div class="pop-in delay-2">
            <button
              class="w-full flex items-center gap-2.5 px-4.5 py-2.5 rounded-full bg-white/45 border border-white/70 text-parchment-dim/60 hover:bg-white/60 hover:text-parchment transition-all text-[12px] font-body tracking-wide cursor-pointer backdrop-blur-sm shadow-sm"
              id="search-trigger"
              aria-label="搜索"
            >
              <Icon name="lucide:search" width={14} height={14} class="text-brand" />
              <span class="flex-1 text-left font-semibold">搜索文章...</span>
              <span class="flex items-center gap-1 opacity-40">
                <span class="kbd shadow-none border-none bg-white/50 text-[9px]">⌘K</span>
              </span>
            </button>
          </div>
        </div>

        <!-- ========================================= -->
        <!-- 中栏：猫咪问候 + 品牌打字机 + 社交胶囊 (焦点中心) -->
        <!-- ========================================= -->
        <div class="flex flex-col items-center gap-4.5 -mt-3">
          <!-- 猫咪问候卡 (早上好，我是秋知，很高兴认识你) -->
          <div class="pop-in delay-1 w-full draggable-card cursor-grab rounded-[40px]">
            <GreetingCard />
          </div>

          <!-- 品牌卡 (真实的打字机动效有点子就试试) -->
          <div class="pop-in delay-2 w-full draggable-card cursor-grab rounded-[32px]">
            <BrandCard />
          </div>

          <!-- 社交按钮 (小红书 + 哔哩哔哩 + 极简邮箱胶囊) -->
          <div class="flex items-center justify-center gap-2.5 pop-in delay-3 draggable-card cursor-grab w-full">
            <!-- 哔哩哔哩 -->
            <a href="https://space.bilibili.com/1029612512" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/70 text-[#fb7299] hover:bg-white/95 hover:scale-105 transition-all no-underline text-[12px] font-body font-bold shadow-[0_2px_8px_rgba(0,0,0,0.02)] border border-white/60">
              <span class="w-4 h-4 rounded-md bg-[#fb7299] flex items-center justify-center text-white text-[9px] shrink-0 font-sans font-black">b</span>
              哔哩哔哩
            </a>
            <!-- 小红书 -->
            <a href="https://xiaohongshu.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/70 text-[#ff2442] hover:bg-white/95 hover:scale-105 transition-all no-underline text-[12px] font-body font-bold shadow-[0_2px_8px_rgba(0,0,0,0.02)] border border-white/60">
              <span class="w-4 h-4 rounded-md bg-[#ff2442] flex items-center justify-center text-white text-[9px] shrink-0 font-sans font-black">书</span>
              小红书
            </a>
            <!-- 邮件小药丸 -->
            <a href="mailto:praxiswalker@gmail.com" class="w-[34px] h-[34px] rounded-full bg-white/70 text-brand flex items-center justify-center hover:bg-white/95 hover:scale-105 transition-all no-underline shadow-[0_2px_8px_rgba(0,0,0,0.02)] border border-white/60 shrink-0">
              <Icon name="lucide:mail" width={15} height={15} class="stroke-[2.5]" />
            </a>
          </div>
        </div>

        <!-- ========================================= -->
        <!-- 右栏：AI探索装备 -->
        <!-- ========================================= -->
        <div class="flex flex-col gap-4.5 mt-2">
          <!-- 装备库展示卡 -->
          <div class="pop-in delay-1 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[32px]">
            <DockShowcase />
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ========================================= -->
  <!-- 💫 点子流星特效层 -->
  <!-- ========================================= -->
  <div id="spark-meteor-container" class="fixed inset-0 z-40 overflow-hidden pointer-events-none"></div>

  <!-- ========================================= -->
  <!-- 🎁 脑洞点子盲盒水晶模态弹窗 -->
  <!-- ========================================= -->
  <div id="spark-box-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/20 backdrop-blur-md transition-all duration-300 pointer-events-auto">
    <div class="panel-glass p-7 rounded-[40px] w-[340px] flex flex-col items-center justify-center text-center relative border transform scale-95 opacity-0 transition-all duration-300" id="spark-box-card" style="box-shadow: 0 20px 50px var(--color-brand-glow, rgba(53,191,171,0.15)); border-color: var(--color-border, rgba(255,255,255,0.9));">
      
      <!-- 关闭按钮 -->
      <button id="spark-box-close-top" class="absolute top-4 right-4 text-parchment-dim/40 hover:text-parchment transition-colors text-[10px] cursor-pointer">
        <Icon name="lucide:x" width={14} height={14} />
      </button>

      <!-- 发光小灯泡/彩蛋 (自适应) -->
      <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-4 shadow-[0_4px_12px_rgba(53,191,171,0.15)] border transition-colors duration-300" style="background: var(--color-player-icon-bg, #e6fcf9); border-color: var(--color-inner-border, rgba(53,191,171,0.2));">
        <Icon name="lucide:sparkles" width={22} height={22} class="animate-pulse" style="color: var(--color-brand, #35bfab);" />
      </div>

      <div class="text-[10px] font-mono text-parchment-dim/40 tracking-[0.2em] mb-2 uppercase">💡 IDEA UNBOXING</div>
      <h3 class="text-parchment text-[15px] font-body font-bold leading-relaxed mb-4">
        恭喜开出一个好点子！
      </h3>

      <!-- 动态点子展示区 (自适应) -->
      <div class="w-full p-4.5 rounded-2xl border min-h-[90px] flex items-center justify-center mb-6 transition-all duration-300" style="background: var(--color-inner-bg, rgba(255, 255, 255, 0.5)); border-color: var(--color-inner-border, rgba(255, 255, 255, 0.7)); shadow: inset 0 1px 4px rgba(0,0,0,0.01);">
        <p class="text-parchment/80 text-[13px] font-body leading-relaxed tracking-wide font-medium" id="spark-box-content">
          加载中...
        </p>
      </div>

      <!-- 底部控制按钮 -->
      <div class="flex items-center gap-2.5 w-full">
        <button id="spark-box-again" class="flex-1 py-2.5 rounded-full hover:scale-102 active:scale-98 transition-all font-body font-bold text-[12px] cursor-pointer shadow-sm" style="background: var(--color-player-icon-bg, #e6fcf9); color: var(--color-brand, #35bfab); border: 1.5px solid var(--color-inner-border, rgba(53,191,171,0.2));">
          再抽一个!
        </button>
        <button id="spark-box-close" class="px-5 py-2.5 rounded-full bg-parchment/[0.04] text-parchment-dim/70 hover:bg-parchment/[0.08] hover:text-parchment transition-all font-body font-bold text-[12px] cursor-pointer">
          关闭
        </button>
      </div>
    </div>
  </div>

  <!-- ========================================= -->
  <!-- 水晶毛玻璃“自定义流光调色盘”面板 (仅本地 localStorage 存储，不污染仓库) -->
  <!-- ========================================= -->
  <div id="custom-palette-panel" class="fixed bottom-22 left-6 z-50 hidden flex flex-col gap-4 p-4.5 rounded-3xl bg-white/80 backdrop-blur-md border border-white/90 shadow-[0_12px_40px_rgba(0,0,0,0.08)] pointer-events-auto transition-all duration-300 w-[240px]">
    <div class="flex items-center justify-between border-b border-parchment/5 pb-2">
      <span class="text-[12px] font-body font-bold text-parchment/70 flex items-center gap-1.5">
        <Icon name="lucide:sliders" width={12} height={12} class="text-[#35bfab]" />
        自定义调色板 (仅本地)
      </span>
      <button id="close-custom-panel" class="text-parchment-dim hover:text-parchment transition-colors text-[10px] cursor-pointer">
        <Icon name="lucide:x" width={12} height={12} />
      </button>
    </div>
    
    <!-- 4个 Orb 拾色器 -->
    <div class="flex flex-col gap-2.5">
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-body text-parchment-dim/60 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-yellow-400"></span> 暖黄光晕
        </span>
        <input type="color" id="picker-orb-1" class="w-7 h-7 rounded-lg border-2 border-white shadow-sm cursor-pointer overflow-hidden p-0" />
      </div>
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-body text-parchment-dim/60 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-pink-400"></span> 嫩粉光晕
        </span>
        <input type="color" id="picker-orb-2" class="w-7 h-7 rounded-lg border-2 border-white shadow-sm cursor-pointer overflow-hidden p-0" />
      </div>
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-body text-parchment-dim/60 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400"></span> 天青光晕
        </span>
        <input type="color" id="picker-orb-3" class="w-7 h-7 rounded-lg border-2 border-white shadow-sm cursor-pointer overflow-hidden p-0" />
      </div>
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-body text-parchment-dim/60 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span> 嫩绿光晕
        </span>
        <input type="color" id="picker-orb-4" class="w-7 h-7 rounded-lg border-2 border-white shadow-sm cursor-pointer overflow-hidden p-0" />
      </div>
    </div>

    <!-- 重置与清空 -->
    <div class="flex items-center gap-2 pt-1 border-t border-parchment/5">
      <button id="reset-custom-colors" class="flex-1 py-1.5 rounded-xl bg-parchment/[0.04] text-parchment-dim hover:bg-parchment/[0.08] hover:text-parchment transition-all text-[11px] font-body font-bold cursor-pointer text-center">
        恢复默认
      </button>
    </div>
  </div>

  <!-- ========================================= -->
  <!-- 浮动控制中心 (Zoom & 充满活力配色的 Switcher) -->
  <!-- ========================================= -->
  <div id="canvas-controls" class="fixed bottom-6 left-6 z-50 flex items-center gap-3.5 px-4.5 py-3 rounded-2xl bg-white/80 backdrop-blur-md border border-white/90 shadow-[0_8px_32px_rgba(0,0,0,0.06)] pointer-events-auto transition-all duration-300">
    <!-- 缩放工具组 -->
    <div class="flex items-center gap-2 border-r border-parchment/10 pr-3.5">
      <button id="zoom-out" class="w-8 h-8 rounded-lg hover:bg-parchment/5 flex items-center justify-center text-parchment-dim hover:text-parchment transition-all active:scale-95 cursor-pointer" title="缩小">
        <Icon name="lucide:minus" width={14} height={14} />
      </button>
      <span id="zoom-text" class="text-[12px] font-mono font-medium text-parchment/70 min-w-[36px] text-center">100%</span>
      <button id="zoom-in" class="w-8 h-8 rounded-lg hover:bg-parchment/5 flex items-center justify-center text-parchment-dim hover:text-parchment transition-all active:scale-95 cursor-pointer" title="放大">
        <Icon name="lucide:plus" width={14} height={14} />
      </button>
      <button id="zoom-fit" class="w-8 h-8 rounded-lg hover:bg-parchment/5 flex items-center justify-center text-parchment-dim hover:text-parchment transition-all active:scale-95 cursor-pointer ml-1" title="居中适合">
        <Icon name="lucide:target" width={14} height={14} />
      </button>
    </div>

    <!-- 活力配色选择器 -->
    <div class="flex items-center gap-2">
      <Icon name="lucide:palette" width={14} height={14} class="text-parchment/30 mr-1" />
      <button class="theme-pill bg-gradient-to-br from-yellow-300 via-pink-400 to-cyan-400 border border-white/60 shadow-sm" data-theme="nature" title="流光霜雾 (Luminous Mist)"></button>
      <button class="theme-pill bg-gradient-to-br from-fuchsia-500 via-purple-600 to-cyan-500" data-theme="aurora" title="极光霓虹 (Aurora Neon)"></button>
      <button class="theme-pill bg-gradient-to-br from-orange-500 via-rose-500 to-amber-400" data-theme="sunset" title="落日余晖 (Sunset Glow)"></button>
      <button class="theme-pill bg-gradient-to-br from-emerald-500 via-teal-500 to-lime-400" data-theme="mint" title="数码薄荷 (Cyber Mint)"></button>
      
      <!-- 自定义流光色盘触发器 (右侧带小加号，梦幻星彩渐变) -->
      <button id="custom-theme-pill" class="theme-pill bg-gradient-to-br from-indigo-400 via-pink-500 to-yellow-400 flex items-center justify-center relative hover:scale-110 active:scale-95 transition-all cursor-pointer" data-theme="custom" title="自定义流光调色板">
        <Icon name="lucide:plus" width={10} height={10} class="text-white font-bold stroke-[3]" />
      </button>
    </div>
  </div>

  <!-- 底部签名线 -->
  <div class="fixed bottom-4 left-1/2 -translate-x-1/2 z-40 flex items-center gap-2 text-[11px] font-mono text-parchment/25 tracking-wider pop-in delay-6" style="animation-delay: 1s;">
    <span class="status-dot"></span>
    <span>Walker · 行过万里水路</span>
  </div>

  <style is:global>
    /* ========================================= */
    /* 全局 CSS 变量定义：Orbs 配色采用最高级柔和的高饱和马卡龙莫兰迪四色 */
    /* ========================================= */
    :root {
      --orb-color-1: #fee196;
      --orb-color-2: #ffafc8;
      --orb-color-3: #a0f0ff;
      --orb-color-4: #b4f5cd;
    }

    /* 绑定这四个巨大色块 */
    .glow-orb#orb-1 { background: var(--orb-color-1); top: -10%; left: -10%; }
    .glow-orb#orb-2 { background: var(--orb-color-2); bottom: -15%; right: -10%; }
    .glow-orb#orb-3 { background: var(--orb-color-3); top: 20%; right: 15%; }
    .glow-orb#orb-4 { background: var(--orb-color-4); bottom: 10%; left: 20%; }

    /* ========================================= */
    /* 雾蒙蒙遮罩层：提供白雾/黑雾背景，配合高斯模糊 */
    /* ========================================= */
    #mist-overlay {
      background: rgba(251, 251, 248, 0.45); /* 明亮白色大雾 */
    }
    body.theme-aurora #mist-overlay {
      background: rgba(7, 6, 20, 0.5) !important; /* 暗夜紫雾 */
    }
    body.theme-sunset #mist-overlay {
      background: rgba(18, 9, 6, 0.5) !important; /* 夕阳暖雾 */
    }
    body.theme-mint #mist-overlay {
      background: rgba(4, 15, 12, 0.5) !important; /* 薄荷冷雾 */
    }
    body.theme-custom #mist-overlay {
      background: rgba(251, 251, 248, 0.45) !important; /* 自定义默认为亮晶白雾 */
    }

    /* 浮在迷雾之上的晶莹剔透 Bento 卡片 (悬浮白玉晶体面板) */
    .panel-glass {
      background: rgba(255, 255, 255, 0.65) !important;
      backdrop-filter: blur(32px) !important;
      border: 1.5px solid rgba(255, 255, 255, 0.9) !important;
      transition: all 0.45s cubic-bezier(0.16, 1, 0.3, 1) !important;
    }

    /* ========================================= */
    /* 四套系统默认活力配色方案对应的 CSS 变量映射 */
    /* ========================================= */
    
    /* 1. 流光霜雾 (Luminous Mist) */
    body.theme-nature {
      background: #fbfbf8 !important;
      color: #1a2325 !important;
      --color-brand: #35bfab; /* 翡翠青 */
      --color-brand-glow: rgba(53, 191, 171, 0.4);
      --color-brand-secondary: #00f2fe;
      --color-parchment: #1a2325;
      --color-parchment-dim: #64748b;
      --color-card: rgba(255, 255, 255, 0.65);
      --color-border: rgba(255, 255, 255, 0.9);
      --color-bg: #fbfbf8;
      
      --orb-color-1: #fee196;
      --orb-color-2: #ffafc8;
      --orb-color-3: #a0f0ff;
      --orb-color-4: #b4f5cd;

      /* 内嵌框样式变量 */
      --color-inner-bg: rgba(255, 255, 255, 0.45);
      --color-inner-border: rgba(0, 0, 0, 0.04);
      --color-inner-shadow: rgba(255, 255, 255, 0.4);

      /* 音乐播放器变量 */
      --color-player-icon-bg: #e6fcf9;
      --color-player-icon-text: #35bfab;
      --color-player-btn-bg: #ffffff;
      --color-player-btn-text: #35bfab;
      --color-player-btn-border: rgba(0, 0, 0, 0.04);
    }
    body.theme-nature .panel-glass {
      box-shadow: 
        inset 0 1px 2px rgba(255, 255, 255, 0.6),
        0 4px 20px -6px rgba(26, 35, 37, 0.04),
        0 24px 50px -12px rgba(26, 35, 37, 0.07) !important;
    }
    body.theme-nature .panel-glass:hover {
      background: rgba(255, 255, 255, 0.75) !important;
      border-color: rgba(255, 255, 255, 0.98) !important;
      box-shadow: 
        inset 0 1px 3px rgba(255, 255, 255, 0.8),
        0 12px 36px -8px rgba(26, 35, 37, 0.06),
        0 32px 60px -24px rgba(26, 35, 37, 0.12) !important;
    }

    /* 2. 极光霓虹 (Aurora Neon) */
    body.theme-aurora {
      background: #070614 !important;
      color: #f3f4f6 !important;
      --color-brand: #d946ef; /* 霓虹玫红 */
      --color-brand-glow: rgba(217, 70, 239, 0.4);
      --color-brand-secondary: #06b6d4; /* 霓虹青 */
      --color-parchment: #f3f4f6;
      --color-parchment-dim: #9ca3af;
      --color-card: rgba(18, 14, 38, 0.45);
      --color-border: rgba(255, 255, 255, 0.07);
      --color-bg: #070614;
      
      --orb-color-1: #ec4899;
      --orb-color-2: #06b6d4;
      --orb-color-3: #6366f1;
      --orb-color-4: #a855f7;

      /* 内嵌框样式变量 */
      --color-inner-bg: rgba(0, 0, 0, 0.25);
      --color-inner-border: rgba(255, 255, 255, 0.06);
      --color-inner-shadow: rgba(0, 0, 0, 0.3);

      /* 音乐播放器变量 */
      --color-player-icon-bg: rgba(217, 70, 239, 0.15);
      --color-player-icon-text: #06b6d4;
      --color-player-btn-bg: rgba(255, 255, 255, 0.9);
      --color-player-btn-text: #d946ef;
      --color-player-btn-border: rgba(255, 255, 255, 0.2);
    }
    body.theme-aurora .panel-glass {
      background: rgba(18, 14, 38, 0.45) !important;
      border-color: rgba(255, 255, 255, 0.07) !important;
      color: #f3f4f6 !important;
      box-shadow: 
        inset 0 1px 2px rgba(255, 255, 255, 0.06),
