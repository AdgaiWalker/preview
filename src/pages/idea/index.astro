---
/**
 * /ai — AI 空间统一入口门户页面 (AI Unified Portal)
 * 极致高奢极简设计，莫兰迪渐变空气感，搭载晶莹剔透毛玻璃卡片和微物理 Hover 反馈。
 */
import Base from '../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { DOCK, AI_IDEAS, AI_TOOLKIT, AI_SOURCES } from '@/lib/routes';

export const prerender = true;

const portalCards = [
  {
    title: 'AI 探索',
    english: 'AI Explorer',
    description: '日常高频提效工具、定制化 Claude Code Skills 技能、前沿内容源与极客微信群交流通道。',
    href: DOCK,
    icon: 'lucide:package',
    badge: '旗舰通道',
    badgeClass: 'badge-primary',
    tag: 'EXPLORE & CHAT',
  },
  {
    title: '创意脑洞',
    english: 'Idea Board',
    description: '有点子，先动手，再开口。这里记录了我对前沿 AI 技术的脑洞创意、灵感爆发与落地方案。',
    href: AI_IDEAS,
    icon: 'lucide:lightbulb',
    badge: '灵感看板',
    badgeClass: 'badge-tertiary',
    tag: 'INSPIRATIONS',
  },
  {
    title: '极客工具箱',
    english: 'Toolkit',
    description: '汇聚高频推荐的 AI 工具、多平台极简客户端、大模型中转等详细大表，内置一键直达与评分。',
    href: AI_TOOLKIT,
    icon: 'lucide:wrench',
    badge: '直达数据库',
    badgeClass: 'badge-quaternary',
    tag: 'TOOL MATCHES',
  },
  {
    title: '优质信息源',
    english: 'Sources',
    description: '秋知长期关注并强烈推荐的优质开发技术博客、前沿 Newsletter 与数字科技播客源泉。',
    href: AI_SOURCES,
    icon: 'lucide:radio',
    badge: '内容源订阅',
    badgeClass: 'badge-quinary',
    tag: 'FEEDS & LINKS',
  },
];
---

<Base 
  title="Idea 空间 — Walker"
  description="行过万重 AI 浪潮，点石成金的数字实验室。在这里，有点子，先动手，再开口。"
>
  <div class="ai-portal-shell animate-fade-in">
    {/* 宏大奢华 Hero 区 */}
    <header class="portal-hero">
      <div class="hero-glow-tag">
        <span class="pulse-dot"></span>
        <span class="text-[10px] font-mono tracking-[0.25em] uppercase text-brand">Walker Digital Lab</span>
      </div>
      <h1 class="hero-title">Idea 空间</h1>
      <p class="hero-subtitle">
        行过万重 AI 浪潮，点石成金的数字实验室。在这里，有点子，先动手，再开口。用点子驱动 AI，去到一个没有重复劳作的地方。
      </p>
      
      {/* 极简呼吸分割线 */}
      <div class="glow-separator"></div>
    </header>

    {/* 统一入口卡片 Bento Grid (不对称精细网格) */}
    <div class="portal-grid">
      {portalCards.map((card, idx) => (
        <a 
          href={card.href} 
          class:list={[
            "portal-card panel-glass no-underline group reveal-card",
            idx === 0 ? "card-highlight md:col-span-2" : ""
          ]}
        >
          {/* 流光折面发光点 */}
          <div class="spotlight-follow"></div>

          {/* 卡片头部 */}
          <div class="card-header">
            <div class="icon-box">
              <Icon name={card.icon} width={20} height={20} class="text-brand shrink-0 group-hover:scale-110 transition-transform" />
            </div>
            <div class="flex items-center gap-2">
              <span class:list={["badge-pill", card.badgeClass]}>{card.badge}</span>
              <span class="text-[10px] font-mono opacity-30 group-hover:opacity-60 transition-opacity">#{card.tag}</span>
            </div>
          </div>

          {/* 卡片主体 */}
          <div class="card-body">
            <div class="title-wrap">
              <h2 class="card-title">{card.title}</h2>
              <span class="card-english">{card.english}</span>
            </div>
            <p class="card-desc">{card.description}</p>
          </div>

          {/* 卡片底部链接 */}
          <div class="card-footer">
            <span class="explore-hint">
              进入通道
              <Icon name="lucide:arrow-right" width={14} height={14} class="group-hover:translate-x-1 transition-transform" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .ai-portal-shell {
    max-width: 1040px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  /* --- 1. Hero Title Header --- */
  .portal-hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 3.5rem;
  }

  .hero-glow-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.15rem;
    border-radius: 99px;
    background: var(--color-brand-glow);
    border: 1px solid rgba(53, 191, 171, 0.18);
    box-shadow: 0 4px 16px var(--color-brand-glow);
    margin-bottom: 1.5rem;
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--color-brand);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--color-brand);
    animation: beacon-pulse 2s infinite ease-in-out;
  }

  @keyframes beacon-pulse {
    0%, 100% { transform: scale(0.85); opacity: 0.5; }
    50% { transform: scale(1.3); opacity: 1; }
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 6vw, 3.25rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-parchment);
    margin: 0 0 1.25rem;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--color-parchment) 30%, var(--color-brand) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-parchment-dim);
    opacity: 0.85;
    margin: 0;
  }

  .glow-separator {
    height: 1px;
    max-width: 140px;
    background: linear-gradient(to right, transparent, var(--color-brand), transparent);
    margin: 2.25rem auto 0;
    opacity: 0.6;
    box-shadow: 0 0 10px var(--color-brand);
  }

  /* --- 2. Bento Grid Layout --- */
  .portal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .portal-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portal-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* --- 3. Interactive Portal Cards --- */
  .portal-card {
    position: relative;
    padding: 2rem;
    border-radius: 28px !important;
    border: 1px solid var(--color-border) !important;
    box-shadow: 
      inset 0 1px 2px rgba(255, 255, 255, 0.08),
      0 12px 35px rgba(0, 0, 0, 0.04) !important;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    cursor: pointer;
  }

  .portal-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-brand) !important;
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.12),
      0 18px 45px rgba(0, 0, 0, 0.08),
      0 0 20px var(--color-brand-glow) !important;
  }

  .card-highlight {
    background: rgba(255, 255, 255, 0.72) !important;
    border-color: rgba(53, 191, 171, 0.18) !important;
  }
  
  body.theme-aurora .card-highlight,
  body.theme-sunset .card-highlight,
  body.theme-mint .card-highlight {
    background: rgba(18, 14, 38, 0.55) !important;
  }

  .card-highlight:hover {
    background: rgba(255, 255, 255, 0.8) !important;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.75rem;
    width: 100%;
  }

  .icon-box {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: var(--color-inner-bg);
    border: 1px solid var(--color-inner-border);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 1px 3px rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }

  .portal-card:hover .icon-box {
    background: var(--color-brand-glow);
    border-color: var(--color-brand);
    box-shadow: 0 0 12px var(--color-brand-glow);
  }

  .badge-pill {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .badge-primary { background: rgba(53, 191, 171, 0.12); color: #218f80; }
  .badge-secondary { background: rgba(6, 182, 212, 0.12); color: #0891b2; }
  .badge-tertiary { background: rgba(245, 158, 11, 0.12); color: #d97706; }
  .badge-quaternary { background: rgba(139, 92, 246, 0.12); color: #7c3aed; }
  .badge-quinary { background: rgba(236, 72, 153, 0.12); color: #db2777; }

  /* --- 4. Card Content --- */
  .card-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .title-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-parchment);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .card-english {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--color-parchment-dim);
    opacity: 0.45;
    text-transform: uppercase;
  }

  .card-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--color-parchment-dim);
    opacity: 0.8;
    margin: 0;
  }

  /* --- 5. Card Footer --- */
  .card-footer {
    margin-top: 1.75rem;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    border-top: 1px solid var(--color-inner-border);
    padding-top: 1rem;
    width: 100%;
  }

  .explore-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-brand);
    transition: color 0.3s ease;
  }

  .portal-card:hover .explore-hint {
    color: var(--color-brand-secondary);
  }

  /* --- 6. Micro-animations --- */
  .reveal-card {
    opacity: 0;
    transform: translateY(20px);
    animation: revealSpring 0.65s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }

  .reveal-card:nth-child(1) { animation-delay: 0.05s; }
  .reveal-card:nth-child(2) { animation-delay: 0.12s; }
  .reveal-card:nth-child(3) { animation-delay: 0.19s; }
  .reveal-card:nth-child(4) { animation-delay: 0.26s; }
  .reveal-card:nth-child(5) { animation-delay: 0.33s; }

  @keyframes revealSpring {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
